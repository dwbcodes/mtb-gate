MTB_GATE_SERIAL_PORTS=/dev/ttyACM0,/dev/ttyACM1
MTB_GATE_BAUD=115200
MTB_GATE_BASE_URL=http://192.168.4.1
MTB_GATE_SERIAL_TIMEOUT_MS=15000
MTB_GATE_CONNECT_TIMEOUT_MS=60000
MTB_GATE_TEST_TIMEOUT_MS=120000
MTB_GATE_EXPECT_TIMEOUT_MS=10000

# Destructive topology tests are skipped unless this is set to 1.
MTB_GATE_DESTRUCTIVE=0
MTB_GATE_START_MAC=
MTB_GATE_FINISH_MAC=
MTB_GATE_INTERMEDIATE_MACS=
MTB_GATE_TEST_WIFI_CHANNEL=6
MTB_GATE_SYNC_TIMEOUT_MS=70000
MTB_GATE_ESPNOW_TIMEOUT_MS=70000
MTB_GATE_FAIL_ON_SERIAL_WARNINGS=0
MTB_GATE_SERIAL_ERROR_PATTERN=
MTB_GATE_SERIAL_WARNING_PATTERN=
MTB_GATE_SERIAL_IGNORE_PATTERN=

# Required for destructive tests because device APIs redact stored passwords.
# Example:
# MTB_GATE_RESTORE_SECRETS_JSON={"AA:BB:CC:DD:EE:FF":{"apPassword":"changeme123","staPassword":"router-password"},"11:22:33:44:55:66":{"apPassword":"changeme123","staPassword":"router-password"}}
MTB_GATE_RESTORE_SECRETS_JSON=
